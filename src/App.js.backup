      <div className="absolute top-2 right-2 flex flex-col items-end gap-2">
        <div className="bg-black/50 backdrop-blur-sm text-white text-[10px] px-2 py-1 rounded-full uppercase tracking-wider">
          {taxon.iconic || "Species"}
        </div>
        <IUCNBadge scientificName={taxon.scientific_name} iucnToken={iucnToken} />
      </div>
      {featured && (
