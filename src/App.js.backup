    {type === "loading" ? (
      <Loader className="w-5 h-5 text-emerald-400 animate-spin" />
    ) : (
      <CheckCircle className="w-5 h-5 text-emerald-400" />
    )}
    <span className="font-medium text-sm">{message}</span>
  </div>
);

